<?xml version="1.0" ?>

<world name="demo_world" gravity="0.0 0.0 -9.81">

	<robot name="mmp_panda">
		<model dir="${CS225A_URDF_FOLDER}/mmp_panda" path="mmp_panda.urdf" name="mmp_panda" />
	</robot>

	<static_object name="Base">
		<origin xyz="0.0 0.0 -0.35" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 -0.00635" rpy="0 0 0" />
	        <geometry>
				<box size="7 7 0.0127" />
	        </geometry>
	        <material name="material">
		        <color rgba="0.1 0.1 0.1 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 -0.00635" rpy="0 0 0" />
	        <geometry>
	            <box size="7 7 0.0127" />
	        </geometry>
	    </collision>
	</static_object>

	<!-- Simple kitchen blockout: fridge + back counters/stove + island + sink -->
	<static_object name="fridge">
		<!-- Aligned flush with the far end of the right corner run -->
		<origin xyz="3.15 1.31 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.40" rpy="0 0 0" />
	        <geometry>
				<box size="0.75 0.72 1.80" />
	        </geometry>
	        <material name="fridge_gray">
		        <color rgba="0.65 0.67 0.70 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.40" rpy="0 0 0" />
	        <geometry>
	            <box size="0.75 0.72 1.80" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="counter_back_left">
		<!-- Left counter now touches the stove -->
		<origin xyz="-0.3 -0.9 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="1.4 0.7 0.9144" />
	        </geometry>
	        <material name="counter_white">
		        <color rgba="0.95 0.95 0.95 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="1.4 0.7 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="stove">
		<origin xyz="0.8 -0.9 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="0.8 0.7 0.9144" />
	        </geometry>
	        <material name="stove_black">
		        <color rgba="0.05 0.05 0.05 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="0.8 0.7 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="counter_back_right">
		<!-- Flush with stove edge (no overlap) -->
		<origin xyz="2.0 -0.9 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="1.6 0.7 0.9144" />
	        </geometry>
	        <material name="counter_white">
		        <color rgba="0.95 0.95 0.95 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="1.6 0.7 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="counter_back_right_corner">
		<!-- Corner return on the fridge side, extending toward the front -->
		<origin xyz="3.15 -0.15 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="0.70 2.20 0.9144" />
	        </geometry>
	        <material name="counter_white">
		        <color rgba="0.95 0.95 0.95 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="0.70 2.20 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="dishwasher">
		<!-- Replaces old fridge location: gray counter-height appliance -->
		<origin xyz="-1.32 -0.9 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="0.64 0.70 0.9144" />
	        </geometry>
	        <material name="dishwasher_gray">
		        <color rgba="0.55 0.57 0.60 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="0.64 0.70 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="island">
		<origin xyz="0.7 0.9 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
				<box size="1.8 0.9 0.9144" />
	        </geometry>
	        <material name="island_white">
		        <color rgba="0.98 0.98 0.98 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.1072" rpy="0 0 0" />
	        <geometry>
	            <box size="1.8 0.9 0.9144" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="sink_basin">
		<origin xyz="1.35 0.66 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.5634" rpy="0 0 0" />
	        <geometry>
				<box size="0.40 0.30 0.06" />
	        </geometry>
	        <material name="sink_dark">
		        <color rgba="0.20 0.20 0.22 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.5634" rpy="0 0 0" />
	        <geometry>
	            <box size="0.40 0.30 0.06" />
	        </geometry>
	    </collision>
	</static_object>

	<static_object name="sink_faucet">
		<origin xyz="1.50 0.66 0.0" rpy="0 0 0" />
	    <visual>
	        <origin xyz="0.0 0.0 0.6372" rpy="0 0 0" />
	        <geometry>
				<cylinder length="0.22" radius="0.015" />
	        </geometry>
	        <material name="faucet_gray">
		        <color rgba="0.70 0.70 0.72 1.0" />
	        </material>
	    </visual>
		<collision>
	        <origin xyz="0.0 0.0 0.6372" rpy="0 0 0" />
	        <geometry>
	            <cylinder length="0.22" radius="0.015" />
	        </geometry>
	    </collision>
	</static_object>

	<dynamic_object name="cup">
		<!-- Cup starts above island so it drops near the sink area -->
		<origin xyz="0.9 0.9 1.0" rpy="0 0 0" />
		<inertial>
        	<origin xyz="0 0 0" rpy="0 0 0" />
        	<mass value="10" />
        	<inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0" />
      	</inertial>

	    <visual>
	        <origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
	            <mesh filename="${CS225A_URDF_FOLDER}/test_objects/meshes/visual/cup.obj" />
	        </geometry>
	    </visual>

		<visual>
	        <origin xyz="0 0 0.06" rpy="0 0 0" />
	        <geometry>
	            <box size="0.1 0.1 0.15" />
	        </geometry>
	        <material name="material">
		        <color rgba="1 1 1 1.0" />
	        </material>
	    </visual>

	    <collision>
	        <origin xyz="0 0 0.06" rpy="0 0 0" />
	        <geometry>
	            <box size="0.1 0.1 0.15" />
	        </geometry>
	    </collision>
	</dynamic_object>

	<dynamic_object name="ladle">
		<!-- Resting on the island surface (island top z ≈ 0.9144) -->
		<origin xyz="0.5 0.9 0.5827" rpy="0 0 0" />
		<inertial>
			<!-- CoM and inertia computed from actual mesh geometry at 0.3 kg -->
			<origin xyz="0.11176 0.02270 0.03876" rpy="0 0 0" />
			<mass value="0.3" />
			<inertia ixx="0.000182" iyy="0.002030" izz="0.002067" ixy="-0.000404" ixz="0.0" iyz="0.0" />
		</inertial>
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<mesh filename="${CS225A_URDF_FOLDER}/test_objects/meshes/visual/ladle.obj" />
			</geometry>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0" />
			<geometry>
				<mesh filename="${CS225A_URDF_FOLDER}/test_objects/meshes/collision/ladle_collision.obj" />
			</geometry>
		</collision>
	</dynamic_object>

	<dynamic_object name="tray">
    	<!-- Resting on the island surface next to cup and ladle (island top z ≈ 0.5644) -->
    	<origin xyz="0.1 0.55 0.6" rpy="0 0 0" />
    	<inertial>
        	<origin xyz="0 0 0" rpy="0 0 0" />
        	<mass value="0.8" />
        	<inertia ixx="0.005" iyy="0.009" izz="0.013" ixy="0" ixz="0" iyz="0" />
    	</inertial>
    	<visual>
        	<origin xyz="0 0 0" rpy="1.5708 0 0" />
        	<geometry>
            	<mesh filename="${CS225A_URDF_FOLDER}/test_objects/meshes/visual/tray.obj" scale="0.01 0.01 0.01" />
       	 	</geometry>
        	<material name="tray_silver">
        		<color rgba="0.7 0.7 0.75 1.0" />
        	</material>
    	</visual>
    	<collision>
        	<origin xyz="0.2286 0.1524 0.03175" rpy="1.5708 0 0" />
        	<geometry>
            	<box size="0.508 0.3048 0.0635" />
        	</geometry>
    	</collision>
	</dynamic_object>

	<light name="light1" type="directional">
		<position xyz="2.0 2.0 2.0" />
		<lookat xyz="0.0 0.0 0.0" />
	</light>

	<light name="light2" type="directional">
		<position xyz="-2.0 -2.0 2.0" />
		<lookat xyz="0.0 0.0 0.0" />
	</light>

	<camera name="camera_fixed">
		<position xyz="0.655677 3.83994 3.785" />
		<vertical xyz="0.0 0.0 1.0" />
		<lookat xyz="0.700671 3.02258 3.21064" />
	</camera>

</world>
